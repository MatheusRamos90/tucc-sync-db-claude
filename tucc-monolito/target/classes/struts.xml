<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>

    <constant name="struts.enable.DynamicMethodInvocation" value="false"/>
    <constant name="struts.devMode" value="false"/>
    <constant name="struts.action.extension" value="action"/>
    <constant name="struts.ui.theme" value="simple"/>
    <!-- Exclui recursos estáticos do filtro Struts -->
    <constant name="struts.actionExcludedPatterns"
              value="/favicon\.ico,.*\.(css|js|png|jpg|gif|ico|woff|woff2|ttf|svg)"/>

    <!-- Redireciona raiz para a lista de produtos -->
    <package name="default" namespace="/" extends="struts-default">
        <action name="index">
            <result type="redirect">/produto/listar.action</result>
        </action>
    </package>

    <!-- ============ PRODUTO ============ -->
    <package name="produto" namespace="/produto" extends="struts-default">

        <action name="listar"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoAction"
                method="listar">
            <result>/WEB-INF/jsp/produto/lista.jsp</result>
        </action>

        <action name="novo"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoAction"
                method="novo">
            <result>/WEB-INF/jsp/produto/form.jsp</result>
        </action>

        <action name="editar"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoAction"
                method="editar">
            <result>/WEB-INF/jsp/produto/form.jsp</result>
            <result name="error" type="redirect">/produto/listar.action</result>
        </action>

        <action name="salvar"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoAction"
                method="salvar">
            <result type="redirect">/produto/listar.action</result>
            <result name="input">/WEB-INF/jsp/produto/form.jsp</result>
        </action>

        <action name="excluir"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoAction"
                method="excluir">
            <result type="redirect">/produto/listar.action</result>
        </action>

    </package>

    <!-- ============ EMPRESA ============ -->
    <package name="empresa" namespace="/empresa" extends="struts-default">

        <action name="listar"
                class="br.com.matheushramos.tucc_monolito.action.EmpresaAction"
                method="listar">
            <result>/WEB-INF/jsp/empresa/lista.jsp</result>
        </action>

        <action name="novo"
                class="br.com.matheushramos.tucc_monolito.action.EmpresaAction"
                method="novo">
            <result>/WEB-INF/jsp/empresa/form.jsp</result>
        </action>

        <action name="editar"
                class="br.com.matheushramos.tucc_monolito.action.EmpresaAction"
                method="editar">
            <result>/WEB-INF/jsp/empresa/form.jsp</result>
            <result name="error" type="redirect">/empresa/listar.action</result>
        </action>

        <action name="salvar"
                class="br.com.matheushramos.tucc_monolito.action.EmpresaAction"
                method="salvar">
            <result type="redirect">/empresa/listar.action</result>
            <result name="input">/WEB-INF/jsp/empresa/form.jsp</result>
        </action>

        <action name="excluir"
                class="br.com.matheushramos.tucc_monolito.action.EmpresaAction"
                method="excluir">
            <result type="redirect">/empresa/listar.action</result>
        </action>

    </package>

    <!-- ============ PRODUTO-EMPRESA ============ -->
    <package name="produto-empresa" namespace="/produto-empresa" extends="struts-default">

        <action name="listar"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoEmpresaAction"
                method="listar">
            <result>/WEB-INF/jsp/produto_empresa/lista.jsp</result>
        </action>

        <action name="novo"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoEmpresaAction"
                method="novo">
            <result>/WEB-INF/jsp/produto_empresa/form.jsp</result>
        </action>

        <action name="salvar"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoEmpresaAction"
                method="salvar">
            <result type="redirect">/produto-empresa/listar.action</result>
            <result name="input">/WEB-INF/jsp/produto_empresa/form.jsp</result>
        </action>

        <action name="excluir"
                class="br.com.matheushramos.tucc_monolito.action.ProdutoEmpresaAction"
                method="excluir">
            <result type="redirect">/produto-empresa/listar.action</result>
        </action>

    </package>

</struts>
