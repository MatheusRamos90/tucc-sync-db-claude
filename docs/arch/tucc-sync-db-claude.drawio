          <mxGeometry height="60" width="160" x="470" y="310" as="geometry" />
        </mxCell>
        <mxCell id="5FMv2-AaYWNzOzgoOPXP-6" edge="1" parent="1" source="5FMv2-AaYWNzOzgoOPXP-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" target="0x76R--6hEuoyzaGAdGl-8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FKj-n_WhGmlD4-_hfJjg-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;# Sobre os projetos&lt;/h1&gt;&lt;p&gt;A camada de apresentação (frontend) utiliza estrutura simples com HTML e CSS, utilizando Bootstrap, e as requisições feitas aos servlets são feitas através do Ajax, o qual envia pelo corpo de requisição os dados para persistência no banco de dados Oracle. Existem algumas camadas nessa arquitetura, utilizadas antes da chegada dos microsserviços. Na camada DAO, os dados são persistidos no banco via queries nativas utilizando PreparedStatement, ResultSet entre outros. As transações de banco são iniciadas antes do processo, comitadas após tudo quando não há falhas, mas havendo falhas é dado rollback.&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="850" x="40" y="580" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
