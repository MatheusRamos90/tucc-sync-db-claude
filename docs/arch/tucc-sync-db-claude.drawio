        <mxCell id="0x76R--6hEuoyzaGAdGl-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;b style=&quot;font-size: 18px;&quot;&gt;tucc-monolito&lt;/b&gt;&lt;/h1&gt;&lt;p&gt;Projeto legado desenvolvido em Java 8, JSP, Struts, Javascript, Ajax e Oracle. Aqui simula um projeto monolito muito utilizado em algumas empresas ainda nos tempos de hoje. A regra de negócio e as renderizações de telas acontecem no lado do servidor.&lt;/p&gt;" vertex="1">
          <mxGeometry height="90" width="840" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0x76R--6hEuoyzaGAdGl-2" edge="1" parent="1" source="0x76R--6hEuoyzaGAdGl-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="0x76R--6hEuoyzaGAdGl-9">
