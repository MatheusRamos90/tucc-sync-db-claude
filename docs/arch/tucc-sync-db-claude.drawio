        <mxCell id="uC_cmnYjKfoOW7ZqqsWt-7" parent="uC_cmnYjKfoOW7ZqqsWt-6" style="align=left;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;fontSize=12;verticalAlign=top;resizable=0;rotatable=0;part=1;html=1;whiteSpace=wrap;" value="- ID: NUMERIC(10)&lt;br&gt;- NOME: VARCHAR2&lt;div&gt;- CNPJ: VARCHAR2&lt;br&gt;&lt;div&gt;- DT_CRIACAO: TIMESTAMP&lt;div&gt;- DT_ATUALIZACAO&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;: TIMESTAMP&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
